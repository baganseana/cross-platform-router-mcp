{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cross-platform-router-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "CrossPlatformRouterMCP",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CrossPlatformRouterMCP"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
